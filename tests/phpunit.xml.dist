<?xml version="1.0" encoding="UTF-8"?>
<phpunit bootstrap="bootstrap.php" colors="true">
    <testsuites>
        <testsuite name="Memi Pilates">
            <directory suffix="Test.php">Acceptance</directory>
            <directory suffix="Test.php">Contract</directory>
        </testsuite>
    </testsuites>
    <php>
        <env name="MEMIPILATES_TEST_TIMEZONE" value="America/Toronto"/>
    </php>
</phpunit>
