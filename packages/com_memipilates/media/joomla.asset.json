{
  "$schema": "https://developer.joomla.org/schemas/json-schema/web_assets.json",
  "name": "com_memipilates",
  "version": "1.6.1",
  "description": "Assets publics et borne de présence pour com_memipilates",
  "license": "GPL-2.0-or-later",
  "assets": [
    {
      "name": "com_memipilates.site",
      "type": "style",
      "uri": "com_memipilates/site.css",
      "version": "1.6.1"
    },
    {
      "name": "com_memipilates.portal",
      "type": "style",
      "uri": "com_memipilates/portal.css",
      "version": "1.6.1",
      "dependencies": [
        "com_memipilates.site"
      ]
    },
    {
      "name": "com_memipilates.schedule",
      "type": "script",
      "uri": "com_memipilates/schedule.js",
      "version": "1.6.1",
      "dependencies": [
        "core"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_memipilates.dashboard",
      "type": "script",
      "uri": "com_memipilates/dashboard.js",
      "version": "1.6.1",
      "dependencies": [
        "core",
        "com_memipilates.qr-generator"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_memipilates.booking",
      "type": "script",
      "uri": "com_memipilates/booking.js",
      "version": "1.0.0",
      "dependencies": [
        "core"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_memipilates.checkout",
      "type": "script",
      "uri": "com_memipilates/checkout.js",
      "version": "1.6.1",
      "dependencies": [
        "core"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_memipilates.kiosk",
      "type": "style",
      "uri": "com_memipilates/kiosk.css",
      "version": "1.0.0"
    },
    {
      "name": "com_memipilates.qr-scanner",
      "type": "script",
      "uri": "com_memipilates/vendor/qr-scanner.umd.min.js",
      "version": "1.4.2",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_memipilates.qr-generator",
      "type": "script",
      "uri": "com_memipilates/vendor/qrcode.min.js",
      "version": "1.0.0",
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_memipilates.qr-decoder-adapter",
      "type": "script",
      "uri": "com_memipilates/qr-decoder-adapter.js",
      "version": "1.0.0",
      "dependencies": [
        "com_memipilates.qr-scanner"
      ],
      "attributes": {
        "defer": true
      }
    },
    {
      "name": "com_memipilates.kiosk-scanner",
      "type": "script",
      "uri": "com_memipilates/kiosk.js",
      "version": "1.6.1",
      "dependencies": [
        "core",
        "com_memipilates.qr-decoder-adapter"
      ],
      "attributes": {
        "defer": true
      }
    }
  ]
}
